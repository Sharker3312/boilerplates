        "tooltip": {
          "mode": "single"
        },
        "colWidth": 0.9
      },
      "targets": [
        {
          "expr": "clamp_min(ceil(sum(increase(k6_http_reqs_total{testid=\"$test_name\", expected_response=\"false\", name=~\".*listings.*\"}[2m]))), 0)",
          "refId": "A",
