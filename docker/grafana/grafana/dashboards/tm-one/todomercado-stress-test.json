              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "sum(increase(k6_http_req_failed_total{test=\"$test_name\", condition=\"nonzero\"}[$__range])) / sum(increase(k6_http_reqs_total{test=\"$test_name\"}[$__range])) * 100",
          "refId": "A",
          "legendFormat": "errores"
        }
      ]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Velocidad (P95)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "pluginVersion": "11.2.0",
      "gridPos": { "h": 10, "w": 6, "x": 12, "y": 3 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "max": 10,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_duration_milliseconds_bucket{test=\"$test_name\"}[$__range])) by (le)) / 1000",
          "refId": "A",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Usuarios Simulados",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
