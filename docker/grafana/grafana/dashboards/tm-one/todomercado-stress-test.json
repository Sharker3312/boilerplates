      "title": "¿Cuándo dejó de funcionar?",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Línea de tiempo por funcionalidad. Verde = funcionando, Rojo = con errores, Gris = sin datos (no se estaba ejecutando el test).",
      "pluginVersion": "13.1.0",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 33
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "transparent",
                "value": null
              },
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": {
                  "text": " ",
                  "index": 0
                }
              }
            },
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "OK",
                  "index": 1
                }
              }
