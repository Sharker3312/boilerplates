          "editorMode": "code",
          "expr": "sum(count_over_time({job=~\"lambda|.*lambda.*\", function=~\"${lambda_name:regex}\"} |~ \"(\\\"type\\\":\\\"platform.initStart\\\"|INIT_START)\" [$interval]))",
          "queryType": "range",
          "refId": "A"
