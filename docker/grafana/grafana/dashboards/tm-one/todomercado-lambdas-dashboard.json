          "expr": "(max(max_over_time(({job=~\"lambda|.*lambda.*\", function=~\"${lambda_name:regex}\"} |= \"\\\"type\\\":\\\"platform.report\\\"\" | json max_mem=\"record.metrics.maxMemoryUsedMB\" | unwrap max_mem [$interval]))) or max(max_over_time(({job=~\"lambda|.*lambda.*\", function=~\"${lambda_name:regex}\"} |= \"REPORT RequestId:\" | regexp \"Max Memory Used: (?P<max_mem>[0-9]+) MB\" | unwrap max_mem [$interval]))))",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "description": "Máximo de memoria usada (MB) durante el intervalo, extraído de REPORT/platform.report."
    },
