          "editorMode": "code",
          "expr": "100 * (sum(count_over_time({job=~\"lambda|.*lambda.*\", stage=~\"${stage:regex}\", function=~\"${lambda_name:regex}\"} |~ \"(?i)(\\berror\\b|\\bexception\\b|\\btraceback\\b|task timed out|runtime exited)\" [$interval])) / (sum(count_over_time({job=~\"lambda|.*lambda.*\", stage=~\"${stage:regex}\", function=~\"${lambda_name:regex}\"} |~ \"(\\\"type\\\":\\\"platform.report\\\"|REPORT RequestId:)\" [$interval])) + 0.000001))",
